# Get a free key at https://console.cloud.google.com/ -> APIs & Services -> Safe Browsing API
# Leave blank to run without it (that check will be skipped gracefully).
GOOGLE_SAFE_BROWSING_API_KEY=
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
# Comma-separated list of origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000

# The public URL of your frontend.
# - If tunneling frontend with ngrok: e.g. https://your-frontend-subdomain.ngrok-free.dev
# - If testing on same Wi-Fi: e.g. http://<your-laptop-local-ip>:3000
WEBSITE_URL=http://localhost:3000
